# Recommended to keep for local development
RUST_LOG=colibri_appview=debug,rocket=info

# Database URL to the local PostgreSQL DB
DATABASE_URL=postgres://...
# Maximum concurrent connections from AppView to database
DATABASE_MAX_CONNECTIONS=40

# Hostname & Port for Tap
TAP_HOSTNAME=127.0.0.1:2480
# Tap password
TAP_ADMIN_PASSWORD=...
# How many workers are used to process Tap events
TAP_WORKERS=16

# Private key used for cryptographic proof in ATproto ops
K256_PRIVATE_KEY=...

# The PDS newly created communities live on
PDS_LOC=https://pds.example.com
# Admin password for the PDS
PDS_ADMIN_PASS=...

# The domain that communities get their handles from. (Handles will be example.${APPVIEW_HANDLE_DOMAIN})
APPVIEW_HANDLE_DOMAIN=example.com

# The did:web this AppView identifies as. Self-hosters MUST set this to their own
# identity. Defaults to did:web:api.colibri.social.
APPVIEW_DID=did:web:appview.example.com

# Key used to encrypt app passwords issued for communities
CREDENTIAL_ENCRYPTION_KEY=...

# API Key for KLIPY. Get one from https://partner.klipy.com/
KLIPY_API_KEY=...

# Push notification keys. When self-hosting, the public key must match that of the self-hosted client.
VAPID_PUBLIC_KEY=...
VAPID_PRIVATE_KEY=...
# Push notification subject email
VAPID_SUBJECT=mailto:example@example.com

# Voice SFU (mediasoup). All optional. The SFU is built and enabled by default
# on Linux/macOS; it is unavailable on native Windows (build/run voice via
# WSL2/Docker).
# Number of mediasoup workers. Defaults to the number of CPU cores.
SFU_WORKER_COUNT=
# IP the SFU binds its WebRTC media sockets to. Defaults to 0.0.0.0.
SFU_LISTEN_IP=0.0.0.0
# Public IP announced in ICE candidates. REQUIRED behind NAT (e.g. most cloud
# hosts) so clients can reach the media ports; set it to the server's public IP.
SFU_ANNOUNCED_IP=
# UDP media port range. If both are set, open this range on your firewall and
# forward it to the container. If unset, mediasoup picks ephemeral ports.
SFU_RTC_MIN_PORT=40000
SFU_RTC_MAX_PORT=40100

# STUN/TURN servers handed to clients for ICE, as a JSON array of RTCIceServer
# objects. A TURN server is what lets clients on restrictive/symmetric-NAT
# networks (and some browsers) connect when a direct path to the media ports
# fails. Unset means no ICE servers (direct connection only). Example:
# SFU_ICE_SERVERS=[{"urls":["turn:turn.example.com:3478"],"username":"user","credential":"pass"}]
SFU_ICE_SERVERS=
